.container {
  padding: 60rpx 40rpx;
  background: linear-gradient(180deg, #2C3E50 0%, #34495E 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 72rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 8rpx;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 2rpx;
}

.modules {
  margin-bottom: 60rpx;
}

.module-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s;
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.module-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.daily-icon {
  background: linear-gradient(135deg, #FFE5D9, #FFCDB2);
}

.workplace-icon {
  background: linear-gradient(135deg, #D4E6F1, #AED6F1);
}

.module-info {
  flex: 1;
}

.module-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 26rpx;
  color: #7F8C8D;
  margin-bottom: 16rpx;
}

.module-meta {
  display: flex;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #ECF0F1;
  color: #7F8C8D;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-orange {
  background: rgba(230, 126, 34, 0.1);
  color: #E67E22;
}

.arrow {
  font-size: 32rpx;
  color: #BDC3C7;
  flex-shrink: 0;
}

.tip-section {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.tip-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 2;
  position: relative;
  padding-left: 24rpx;
}

.tip-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #E67E22;
}
