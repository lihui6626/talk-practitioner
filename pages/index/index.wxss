.container {
  padding: 60rpx 40rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 50%, #f093fb 100%);
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo-text {
  font-size: 80rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
}

.logo-text .highlight {
  color: #ffd700;
  text-shadow: 0 0 30rpx rgba(255, 215, 0, 0.6);
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 2rpx;
  margin-bottom: 24rpx;
}

.motivation-tag {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(10px);
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.modules {
  margin-bottom: 60rpx;
}

.module-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 12rpx 40rpx rgba(102, 126, 234, 0.25);
  transition: all 0.3s;
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.2);
}

.module-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin-right: 32rpx;
  flex-shrink: 0;
}

.daily-icon {
  background: linear-gradient(135deg, #ffecd2, #fcb69f);
  box-shadow: 0 8rpx 24rpx rgba(252, 182, 159, 0.4);
}

.workplace-icon {
  background: linear-gradient(135deg, #a1c4fd, #c2e9fb);
  box-shadow: 0 8rpx 24rpx rgba(161, 196, 253, 0.4);
}

.ai-icon {
  background: linear-gradient(135deg, #a8edea, #fed6e3);
  box-shadow: 0 8rpx 24rpx rgba(168, 237, 234, 0.4);
}

.ai-card {
  border: 2rpx dashed #667eea;
  background: linear-gradient(135deg, #f5f7fa 0%, #fff 100%);
}

.module-info {
  flex: 1;
}

.module-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.module-desc {
  font-size: 26rpx;
  color: #606F7B;
  margin-bottom: 16rpx;
}

.module-meta {
  display: flex;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: #ECF0F1;
  color: #7F8C8D;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 12rpx;
}

.tag-orange {
  background: rgba(255, 107, 107, 0.15);
  color: #FF6B6B;
}

.tag-blue {
  background: rgba(102, 126, 234, 0.15);
  color: #667eea;
}

.arrow {
  font-size: 32rpx;
  color: #667eea;
  flex-shrink: 0;
  transition: transform 0.3s;
}

.module-card:active .arrow {
  transform: translateX(8rpx);
}

.tip-section {
  background: rgba(255, 255, 255, 0.2);
  backdrop-filter: blur(10px);
  border-radius: 20rpx;
  padding: 32rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.25);
}

.tip-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.tip-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 2;
  position: relative;
  padding-left: 24rpx;
}

.tip-item::before {
  content: '✨';
  position: absolute;
  left: 0;
}
