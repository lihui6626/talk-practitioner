.container {
  padding: 120rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
}

.content {
  text-align: center;
}

.icon {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 16rpx;
}

.desc {
  font-size: 28rpx;
  color: #7F8C8D;
  margin-bottom: 60rpx;
}

.btn {
  background: linear-gradient(135deg, #E67E22, #D35400);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 28rpx 80rpx;
  font-size: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
}
