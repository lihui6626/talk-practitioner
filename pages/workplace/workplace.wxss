.container {
  padding: 60rpx 40rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.header-title {
  font-size: 44rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 12rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #7F8C8D;
  line-height: 1.6;
}

.scenes {
  margin-bottom: 60rpx;
}

.scene-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s;
}

.scene-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.scene-icon {
  width: 80rpx;
  height: 80rpx;
  background: #EBF5FB;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.scene-info {
  flex: 1;
}

.scene-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #2C3E50;
  margin-bottom: 8rpx;
}

.scene-count {
  font-size: 24rpx;
  color: #BDC3C7;
}

.scene-arrow {
  font-size: 28rpx;
  color: #BDC3C7;
}

.tips {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  border-left: 6rpx solid #3498DB;
}

.tips-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 20rpx;
}

.tips-item {
  font-size: 26rpx;
  color: #5D6D7E;
  line-height: 2;
  padding-left: 20rpx;
  position: relative;
}

.tips-item::before {
  content: '•';
  position: absolute;
  left: 0;
  color: #3498DB;
}
