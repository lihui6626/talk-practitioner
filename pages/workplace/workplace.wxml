<!--workplace.wxml-->
<view class="container">
  <view class="header">
    <view class="header-icon">💼</view>
    <view class="header-title">职场逻辑表达</view>
    <view class="header-desc">在汇报、评审、面试、跨部门沟通等场景中练习结构化表达</view>
  </view>

  <view class="scenes">
    <block wx:for="{{scenes}}" wx:key="id">
    <view class="scene-item" bindtap="selectScene" data-scene="{{item.id}}">
      <view class="scene-icon">{{item.icon}}</view>
      <view class="scene-info">
        <view class="scene-name">{{item.name}}</view>
        <view class="scene-count">{{item.count}}道练习题</view>
      </view>
      <view class="scene-arrow">→</view>
    </view>
    </block>
  </view>

  <view class="tips">
    <view class="tips-title">练习要点</view>
    <view class="tips-item">结论先行：先说结论再说原因</view>
    <view class="tips-item">逻辑结构：金字塔原理，分层清晰</view>
    <view class="tips-item">数据支撑：用数据说话，而非主观判断</view>
    <view class="tips-item">预判能力：提前预判并回应可能的质疑</view>
  </view>
</view>
