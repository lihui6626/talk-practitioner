<!--ai-expand.wxml-->
<view class="container">
  <view class="header">
    <view class="header-icon">🤖</view>
    <view class="header-title">AI扩展题库</view>
    <view class="header-desc">通过AI生成更多练习题目，丰富题库</view>
  </view>

  <view class="tabs">
    <view class="tab {{activeTab === 'daily' ? 'active' : ''}}" bindtap="switchTab" data-tab="daily">日常接话</view>
    <view class="tab {{activeTab === 'workplace' ? 'active' : ''}}" bindtap="switchTab" data-tab="workplace">职场逻辑</view>
  </view>

  <view class="content">
    <view class="section-title">选择场景</view>
    <view class="scenes-grid">
      <block wx:for="{{activeTab === 'daily' ? dailyStats : workplaceStats}}" wx:key="id">
        <view class="scene-card {{selectedScene === item.id ? 'selected' : ''}}" bindtap="selectScene" data-scene="{{item.id}}">
          <view class="scene-icon">{{item.icon}}</view>
          <view class="scene-name">{{item.name}}</view>
          <view class="scene-count">{{item.count}}道</view>
        </view>
      </block>
    </view>

    <view class="action-section">
      <view class="selected-info" wx:if="{{selectedScene}}">
        已选择：{{getSceneName(selectedScene)}}
      </view>
      <button class="generate-btn" bindtap="generateQuestions" loading="{{isGenerating}}">
        🤖 AI生成{{aiGenerateCount}}道题目
      </button>
      <view class="message" wx:if="{{message}}">{{message}}</view>
    </view>

    <!-- 赞助区域 -->
    <view class="sponsor-section">
      <view class="sponsor-title">💝 赞助开发者</view>
      <view class="sponsor-desc">如果这个项目对你有帮助，欢迎赞助支持</view>
      <button class="sponsor-btn" bindtap="sponsor" type="primary" size="mini">
        ❤️ 赞助 ¥{{sponsorAmount}}
      </button>
    </view>

    <view class="tips-section">
      <view class="tips-title">说明</view>
      <view class="tips-item">• AI将根据已有题目生成相似但不重复的新题</view>
      <view class="tips-item">• 生成的题目会自动添加到对应场景</view>
      <view class="tips-item">• 每次生成{{aiGenerateCount}}道题目，节约成本</view>
    </view>
  </view>
</view>