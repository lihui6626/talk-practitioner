page {
  background-color: #F8F9FA;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  color: #2C3E50;
}

.container {
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #2C3E50;
  text-align: center;
  margin-bottom: 16rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #7F8C8D;
  text-align: center;
  margin-bottom: 60rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #E67E22, #D35400);
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 28rpx 48rpx;
  font-size: 32rpx;
  font-weight: 500;
  box-shadow: 0 8rpx 24rpx rgba(230, 126, 34, 0.3);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  background: #ECF0F1;
  color: #7F8C8D;
  border-radius: 16rpx;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.tag-orange {
  background: rgba(230, 126, 34, 0.1);
  color: #E67E22;
}

.score-badge {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.score-low {
  background: #FFE5E5;
  color: #E74C3C;
}

.score-mid {
  background: #FFF4E5;
  color: #F39C12;
}

.score-high {
  background: #E8F8F0;
  color: #27AE60;
}

.option-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #ECF0F1;
  transition: all 0.3s;
}

.option-item.selected {
  border-color: #E67E22;
  background: rgba(230, 126, 34, 0.05);
}

.option-item.correct {
  border-color: #27AE60;
  background: rgba(39, 174, 96, 0.05);
}

.option-item.wrong {
  border-color: #E74C3C;
  background: rgba(231, 76, 60, 0.05);
}

.option-key {
  display: inline-block;
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  background: #ECF0F1;
  color: #7F8C8D;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.option-key.selected {
  background: #E67E22;
  color: #fff;
}

.analysis-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-top: 32rpx;
}

.analysis-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C3E50;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.analysis-title::before {
  content: '';
  display: inline-block;
  width: 6rpx;
  height: 32rpx;
  background: #E67E22;
  margin-right: 16rpx;
  border-radius: 3rpx;
}

.analysis-text {
  font-size: 28rpx;
  color: #5D6D7E;
  line-height: 1.8;
}
